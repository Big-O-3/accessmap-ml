# Hugging Face Inference API token. Read-scope is enough.
# Create at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# Origin allowed to hit /analyze in production. Locally you can leave this
# unset (defaults to "*"). In prod, set to your backend's Render URL, e.g.
# https://accessmap-backend.onrender.com
CORS_ORIGIN=

# Port the Flask server binds to. Render sets PORT automatically, so leave
# this unset in production. Local dev defaults to 5001.
PORT=5001
